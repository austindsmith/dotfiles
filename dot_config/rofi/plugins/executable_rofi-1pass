#!/usr/bin/env bash
set -euo pipefail

notify() {
    notify-send -t 2000 "1Password" "$1"
}

copy() {
    printf '%s' "$1" | wl-copy >/dev/null 2>&1
}

list_items() {
    printf '\0prompt\x1f1Password\n'
    printf '\0no-custom\x1ftrue\n'
    op item list --format json |
        jq -r '.[] | "\(.title)\u0000info\u001fitem:\(.id)\u001ficon\u001f1password"'
}

list_actions() {
    local id="$1"
    printf '\0prompt\x1f1Password\n'
    printf '\0no-custom\x1ftrue\n'
    printf 'Copy password\0info\x1faction:%s:password\x1ficon\x1fdialog-password\n' "$id"
    printf 'Copy username\0info\x1faction:%s:username\x1ficon\x1favatar-default\n' "$id"
    printf 'Copy OTP\0info\x1faction:%s:otp\x1ficon\x1fclock\n' "$id"
    printf 'Copy URL\0info\x1faction:%s:url\x1ficon\x1femblem-web\n' "$id"
    printf 'Open URL\0info\x1faction:%s:open\x1ficon\x1fweb-browser\n' "$id"
    printf 'Back\0info\x1fback\x1ficon\x1fgo-previous\n'
}

run_action() {
    local id="$1" action="$2" value

    case "$action" in
        password)
            value=$(op item get "$id" --fields label=password --reveal)
            copy "$value"
            notify "Password copied"
            ;;
        username)
            value=$(op item get "$id" --fields label=username --reveal)
            copy "$value"
            notify "Username copied"
            ;;
        otp)
            value=$(op item get "$id" --otp)
            copy "$value"
            notify "OTP copied"
            ;;
        url)
            value=$(op item get "$id" --format json | jq -r '.urls[0].href // empty')
            copy "$value"
            notify "URL copied"
            ;;
        open)
            value=$(op item get "$id" --format json | jq -r '.urls[0].href // empty')
            xdg-open "$value" >/dev/null 2>&1
            ;;
    esac
}

info="${ROFI_INFO:-}"

if [[ -z "$info" || "$info" == "back" ]]; then
    list_items
    exit 0
fi

if [[ "$info" == item:* ]]; then
    list_actions "${info#item:}"
    exit 0
fi

if [[ "$info" == action:* ]]; then
    rest="${info#action:}"
    id="${rest%%:*}"
    action="${rest##*:}"
    run_action "$id" "$action" >/dev/null 2>&1 &
    disown
    exit 0
fi
