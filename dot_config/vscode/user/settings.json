{
  "workbench.colorTheme": "Catppuccin Macchiato",
  "workbench.iconTheme": "catppuccin-macchiato",
  "catppuccin-icons.associations.extensions": {},
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "markdowntable.formatOnSave": true,
  "latex-workshop.bibtex-format.sort.enabled": true,
  "latex-workshop.format.fixQuotes.enabled": true,
  "latex-workshop.message.information.show": true,
  "search.exclude": {
    "**/*.aux": true,
    "**/*.log": true,
    "**/*.out": true,
    "**/*.fls": true,
    "**/*.fdb_latexmk": true,
    "**/*.synctex.gz": true,
  },
  "files.saveConflictResolution": "overwriteFileOnDisk",
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.fontFamily": "'FiraCode Nerd Font', monospace",
  "terminal.integrated.fontFamily": "'FiraCode Nerd Font', monospace",
  "[latex]": {
    "editor.defaultFormatter": "James-Yu.latex-workshop",
  },
  "latex-workshop.formatting.latex": "tex-fmt",
  "explorer.confirmDelete": false,
  "editor.minimap.enabled": false,
  "latex-workshop.format.fixMath.enabled": true,
  "explorer.confirmDragAndDrop": false,
  "files.exclude": {
    "**/.git": false,
  },
  "workbench.editor.pinnedTabsOnSeparateRow": true,
  "editor.suggest.preview": true,
  "workbench.editor.enablePreviewFromQuickOpen": true,
  "workbench.editor.enablePreviewFromCodeNavigation": true,
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
  },
}
