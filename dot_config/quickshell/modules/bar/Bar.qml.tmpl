import Quickshell
import Quickshell.Wayland
import Quickshell.Io
import Quickshell.Hyprland
import QtQuick
import QtQuick.Layouts
import "../../config"
import "../../services"

PanelWindow {
    id: root
    screen: Quickshell.screens[{{ if eq .device.name "laptop" }}0{{ else }}2{{ end }}]
    property int cpuUsage: 0
    property int memUsage: 0
    property var lastCpuIdle: 0
    property var lastCpuTotal: 0
    property string activeSpecial: ""

    Connections {
        target: Hyprland
        function onRawEvent(event) {
            if (event.name === "activespecial")
                root.activeSpecial = event.data.split(",")[0];
        }
    }
    anchors.top: true
    anchors.left: true
    anchors.right: true
    implicitHeight: 30
    color: "transparent"

    margins {
        top: 16
        left: 12
        right: 12
    }

    Rectangle {
        anchors.fill: parent
        color: Theme.background
        opacity: Theme.backgroundOpacity
        border.width: 0
        radius: 6
    }

    Item {
        anchors.fill: parent
        anchors.leftMargin: 16
        anchors.rightMargin: 16

        RowLayout {
            id: leftSection
            anchors.left: parent.left
            anchors.verticalCenter: parent.verticalCenter
            spacing: 4

            Repeater {
                model: 9

                Rectangle {
                    property var ws: Hyprland.workspaces.values.find(w => w.id === index + 1)
                    property bool isActive: Hyprland.focusedWorkspace?.id === (index + 1)

                    implicitWidth: 24
                    implicitHeight: 22
                    radius: 6
                    color: isActive ? Theme.selection : "transparent"

                    Text {
                        anchors.centerIn: parent
                        text: index + 1
                        color: parent.isActive ? Theme.accent : (parent.ws ? Theme.steel : Theme.slate)
                        font {
                            family: Theme.fontFamily
                            pixelSize: Theme.fontSizeNormal
                            bold: true
                        }
                    }

                    MouseArea {
                        anchors.fill: parent
                        onClicked: Hyprland.dispatch("hl.dsp.focus({ workspace = " + (index + 1) + " })")
                    }
                }
            }
            Repeater {
                model: ScriptModel {
                    values: Hyprland.workspaces.values.filter(w => w.id < 0)
                }

                Rectangle {
                    id: specialPill

                    required property var modelData
                    readonly property string shortName: modelData.name.replace("special:", "")
                    readonly property bool shown: root.activeSpecial === modelData.name

                    implicitWidth: label.implicitWidth + 12
                    implicitHeight: 22
                    radius: 6
                    color: shown ? Theme.selectionPurple : "transparent"

                    Text {
                        id: label
                        anchors.centerIn: parent
                        text: specialPill.shortName
                        color: specialPill.shown ? Theme.purple : Theme.slate
                        font {
                            family: Theme.fontFamily
                            pixelSize: Theme.fontSizeNormal
                            bold: true
                        }
                    }

                    MouseArea {
                        anchors.fill: parent
                        onClicked: Hyprland.dispatch('hl.dsp.workspace.toggle_special("' + specialPill.shortName + '")')
                        onWheel: event => Hyprland.dispatch(event.angleDelta.y > 0 ? "workspace e-1" : "workspace e+1")
                    }
                }
            }
        }

        Text {
            id: clock
            anchors.centerIn: parent
            color: Theme.sage
            font {
                family: Theme.fontFamily
                pixelSize: Theme.fontSizeNormal
                bold: true
            }
            text: Qt.formatDateTime(new Date(), "ddd, MMM dd - hh:mm AP")
            Timer {
                interval: 1000
                running: true
                repeat: true
                onTriggered: clock.text = Qt.formatDateTime(new Date(), "ddd, MMM dd - hh:mm AP")
            }
        }

        RowLayout {
            id: rightSection
            anchors.right: parent.right
            anchors.verticalCenter: parent.verticalCenter
            spacing: 8

            IconTray {}

            Rectangle {
                implicitWidth: 1
                implicitHeight: 16
                color: Theme.bronze
            }

            Text {
                text: "CPU: " + cpuUsage + "%"
                color: Theme.accent
                font {
                    family: Theme.fontFamily
                    pixelSize: Theme.fontSizeNormal
                    bold: true
                }
            }

            Rectangle {
                implicitWidth: 1
                implicitHeight: 16
                color: Theme.bronze
            }

            Text {
                text: "Mem: " + memUsage + "%"
                color: Theme.sand
                font {
                    family: Theme.fontFamily
                    pixelSize: Theme.fontSizeNormal
                    bold: true
                }
            }

            Rectangle {
                implicitWidth: 1
                implicitHeight: 16
                color: Theme.bronze
            }

            Audio {}
        }
    }
}
