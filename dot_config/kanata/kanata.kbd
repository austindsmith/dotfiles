;; Rebinds CAPS LOCK to be ESC when pressed and MAIN MOD when held
(defcfg
  linux-dev /dev/input/by-id/usb-Razer_Razer_BlackWidow_V4-event-kbd
  process-unmapped-keys yes
  concurrent-tap-hold yes
)
(defsrc
  caps
)
(defalias
  capesc (tap-hold 200 200 esc lmet)
)
(deflayer base
  @capesc
)
(defchordsv2
  (j k) esc 50 all-released ()
)
