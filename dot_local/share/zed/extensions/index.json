        "first_line_pattern": "^#!.*ansible",
        "modeline_aliases": []
      },
      "hidden": false,
      "grammar": "yaml"
    },
    "HCL": {
      "extension": "terraform",
      "path": "languages/hcl",
      "matcher": {
        "path_suffixes": [
          "hcl"
